rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPERS ====================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMerchant() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'merchant';
    }

    function isAdmin() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ==================== USERS ====================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
                    && !('role' in request.resource.data.diff(resource.data).affectedKeys())
                    && !('totalSpending' in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if false;
    }

    // ==================== PETS ====================
    match /pets/{petId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if false; // pets ถูกสร้างผ่าน Cloud Function เท่านั้น
      allow update: if false;
      allow delete: if false;
    }

    // ==================== QUESTS ====================
    match /quests/{questId} {
      allow read: if isSignedIn();
      allow write: if false; // quests จัดการผ่าน Cloud Function/Admin เท่านั้น
    }

    // ==================== JIGSAWS ====================
    match /jigsaws/{jigsawId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false; // เก็บผ่าน Cloud Function เท่านั้น (ป้องกันโกง)
    }

    // ==================== VOUCHERS ====================
    match /vouchers/{voucherId} {
      allow read: if isSignedIn() &&
                  (resource.data.userId == request.auth.uid ||
                   resource.data.merchantId == request.auth.uid ||
                   isAdmin());
      allow write: if false; // ออกและ redeem ผ่าน Cloud Function เท่านั้น
    }

    // ==================== MERCHANTS ====================
    match /merchants/{merchantId} {
      allow read: if isSignedIn();
      allow create: if isMerchant() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ==================== ECONOMIC IMPACTS ====================
    match /economic_impacts/{impactId} {
      allow read: if isSignedIn() &&
                  (resource.data.userId == request.auth.uid ||
                   resource.data.merchantId == request.auth.uid ||
                   isAdmin());
      allow write: if false; // คำนวณผ่าน Cloud Function เท่านั้น
    }
  }
}
